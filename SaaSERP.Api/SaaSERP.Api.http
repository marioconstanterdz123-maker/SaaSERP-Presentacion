### 1. Dar de alta la Barbería (Reemplaza TU_TOKEN_SUPERADMIN)
POST {{HostAddress}}/api/Negocios
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Lb3FKZBaUr_kNfMbEOYjIocnjJnqiATGiI0RCa6M-j4
Content-Type: application/json

{
  "nombre": "Barbería Victoria",
  "telefonoWhatsApp": "8340001111",
  "activo": true,
  "sistemaAsignado": "CITAS",
  "capacidadMaxima": 5,
  "duracionMinutosCita": 30,
  "usaMesas": false
}
### 2. Registrar a Pedro, el dueño
POST {{HostAddress}}/api/Auth/registrar
Content-Type: application/json

