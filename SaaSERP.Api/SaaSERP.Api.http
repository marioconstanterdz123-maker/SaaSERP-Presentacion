  "nombre": "Pedro Barbero",
  "correo": "pedro@barberia.com",
  "password": "PasswordBarbero123",
  "negocioId": 2,
  "rol": "AdminNegocio"
}
### 3. Login de Pedro
POST {{HostAddress}}/api/Auth/login
Content-Type: application/json

{
  "correo": "pedro@barberia.com",
  "password": "PasswordBarbero123"
}
