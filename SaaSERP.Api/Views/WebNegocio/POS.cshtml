@{
    var negocioId = ViewBag.NegocioId;
    ViewData["Title"] = "Punto de Venta";
}
@await Html.PartialAsync("_NegocioShellTop")

<div class="flex flex-col sm:flex-row gap-3 animate-fade-in-up pb-36 sm:pb-6 relative h-full">

    <!-- LEFT: Catalog + Active Orders -->
    <div class="flex-1 flex flex-col gap-3 min-w-0" style="height:calc(100vh - 6rem); overflow-y:auto; padding-right:.5rem;">
        
        <!-- Mesa Selector -->
        <div id="mesas-wrap" class="hidden bg-white/60 backdrop-blur-xl rounded-2xl border border-white p-4 shadow-sm">
            <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-3 flex items-center gap-2">
                <span id="icon-layout" class="text-indigo-600"></span> Seleccionar Mesa
            </h3>
            <div id="mesas-grid" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Search bar -->
        <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400" id="icon-search-p"></span>
            <input type="search" id="inp-search" placeholder="Buscar producto..." oninput="filtrarProductos(this.value)" class="w-full bg-white/70 backdrop-blur border border-white rounded-xl pl-10 pr-4 py-3 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-400 shadow-sm placeholder-slate-400" />
        </div>

        <!-- Product Grid -->
        <div class="bg-white/60 backdrop-blur-xl rounded-2xl border border-white p-4 shadow-sm flex-1">
            <h2 class="text-base font-black text-slate-800 mb-3 flex items-center gap-2">
                <span id="icon-coffee-p" class="text-indigo-600"></span> Menú de Productos
            </h2>
            <div id="pos-loading" class="flex justify-center py-10"><div class="spinner spinner-orange"></div></div>
            <div id="catalog-empty" class="hidden text-center py-12 text-slate-400">
                <span id="icon-nav-empty" class="mx-auto mb-4 opacity-30 text-4xl block"></span>
                <p class="font-medium">No hay productos registrados o activos.</p>
            </div>
            <div id="catalog-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-2.5 hidden"></div>
        </div>

        <!-- Active Orders -->
        <div class="bg-white/60 backdrop-blur-xl rounded-2xl border border-white shadow-sm">
            <button onclick="toggleOrders()" class="w-full flex items-center justify-between p-4 text-left">
                <h3 class="text-sm font-black text-slate-600 uppercase tracking-widest flex items-center gap-2">
                    📋 Órdenes Activas
                    <span id="orders-badge" class="bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded-full text-xs font-bold">0</span>
                </h3>
                <span id="icon-chevron" class="text-slate-400"></span>
            </button>
            <div id="orders-content" class="hidden px-4 pb-4 max-h-72 overflow-y-auto space-y-2"></div>
        </div>
    </div>

    <!-- RIGHT: Cart Panel (Desktop) -->
    <div class="hidden sm:flex w-80 sm:w-96 flex-col bg-slate-800 rounded-2xl sm:rounded-3xl overflow-hidden shadow-2xl relative flex-shrink-0" style="height:calc(100vh - 6rem);">
        <!-- Header -->
        <div class="bg-slate-800 p-4 text-white flex-shrink-0">
            <div class="flex justify-between items-center mb-3">
                <h3 class="text-base font-black flex items-center gap-2">
                    <span id="icon-cart" class="text-indigo-400"></span> Ticket
                </h3>
                <div class="flex rounded-lg overflow-hidden border border-slate-600 text-xs">
                    <button id="btn-tipo-mesa" onclick="setTipoAtencion('Mesa')" class="hidden px-2.5 py-1.5 font-bold transition-colors bg-slate-700 text-slate-300">Mesa</button>
                    <button id="btn-tipo-local" onclick="setTipoAtencion('Mostrador')" class="px-2.5 py-1.5 font-bold transition-colors bg-indigo-600 text-white">Local</button>
                    <button id="btn-tipo-llevar" onclick="setTipoAtencion('Llevar')" class="px-2.5 py-1.5 font-bold transition-colors bg-slate-700 text-slate-300">Llevar</button>
                </div>
            </div>

            <!-- Mode Inputs -->
            <div id="input-mesa-wrap" class="hidden flex items-center gap-2">
                <span id="lbl-mesa-sel" class="bg-indigo-500/30 border border-indigo-400/50 text-indigo-200 px-3 py-2 rounded-xl font-bold text-sm flex-1">🍽️ Selecciona una mesa...</span>
                <button onclick="clearMesa()" class="text-xs text-slate-400 hover:text-white underline whitespace-nowrap">Quitar</button>
            </div>
            <div id="input-text-wrap" class="flex flex-col gap-2">
                <input type="text" id="inp-nombre" placeholder="Nombre Cliente (Local)" class="w-full bg-slate-700/50 border border-slate-600 rounded-xl px-3 py-2.5 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 font-medium text-sm" />
                <input type="tel" id="inp-tel" placeholder="Teléfono (aviso automático)" class="w-full bg-slate-700/50 border border-slate-600 rounded-xl px-3 py-2.5 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-400 font-medium text-sm" />
            </div>
        </div>

        <!-- Items -->
        <div id="cart-items" class="flex-1 overflow-y-auto p-3 space-y-2 bg-slate-50/10"></div>

        <!-- Footer -->
        <div class="bg-white p-4 border-t border-slate-200 flex-shrink-0">
            <div class="flex justify-between items-end mb-3">
                <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Total</span>
                <span id="lbl-total" class="text-2xl font-black text-slate-800">$0.00</span>
            </div>
            <button id="btn-confirmar" onclick="enviarComanda()" class="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 text-white font-black py-4 rounded-xl shadow-lg shadow-indigo-500/30 transition-all active:scale-95 text-base">
                <span id="icon-send"></span> CONFIRMAR COMANDA
            </button>
        </div>
    </div>
</div>

<!-- Overlay Success -->
<div id="overlay-success" class="fixed inset-0 bg-emerald-500/95 backdrop-blur-sm z-50 flex flex-col items-center justify-center text-white p-6 text-center animate-fade-in hidden">
    <span id="icon-check-big" class="mb-4 animate-bounce text-6xl"></span>
    <h2 class="text-2xl font-black mb-2">¡Comanda Enviada!</h2>
    <p id="success-msg" class="font-medium text-emerald-100 mb-6"></p>
</div>

@await Html.PartialAsync("_NegocioShellBottom")

@section Scripts {
<script>
const NEGOCIO_ID = @negocioId;
let negocioData = null;
let allProductos = [];
let comandasActivas = [];
let cart = [];
let mesas = [];
let tipoAtencion = 'Mostrador';
let mesaSeleccionada = '';
let ordersOpen = false;
let userAuth = null;
const CACHE_KEY = `SaaSERP_Cart_${NEGOCIO_ID}`;

(async function init() {
    userAuth = requireAuth();
    if (!userAuth) return;
    
    // Load icons
    document.getElementById('icon-menu-btn').innerHTML = ICONS.menu;
    document.getElementById('icon-x-drawer').innerHTML = ICONS.x;
    document.getElementById('icon-layout').innerHTML = ICONS.layoutGrid || '🔲';
    document.getElementById('icon-search-p').innerHTML = ICONS.search || '🔍';
    document.getElementById('icon-coffee-p').innerHTML = ICONS.coffee || '☕';
    document.getElementById('icon-nav-empty').innerHTML = ICONS.navigation || '🧭';
    document.getElementById('icon-chevron').innerHTML = ICONS.chevronDown || '▼';
    document.getElementById('icon-cart').innerHTML = ICONS.shoppingCart || '🛒';
    document.getElementById('icon-send').innerHTML = ICONS.send || '📤';
    document.getElementById('icon-check-big').innerHTML = ICONS.checkCircle || '✅';

    try {
        const negociosRes = await apiFetch('/negocios');
        negocioData = negociosRes.find(n => n.id == NEGOCIO_ID);
        renderNegocioNav(userAuth, negocioData);

        if (negocioData && negocioData.usaMesas) {
            document.getElementById('btn-tipo-mesa').classList.remove('hidden');
            const recs = await apiFetch(`/Recursos/negocio/${NEGOCIO_ID}`).catch(()=>[]);
            mesas = recs.filter(r => r.activo);
            renderMesas();
        }

        const prod = await apiFetch(`/servicios/negocio/${NEGOCIO_ID}`).catch(()=>[]);
        allProductos = prod.filter(p => p.activo);
        renderCatalog(allProductos);
        
        loadCart();
        fetchComandas();
        setInterval(fetchComandas, 15000);
    } catch(err) {
        showToast('Error cargando POS', 'error');
    } finally {
        document.getElementById('pos-loading').classList.add('hidden');
    }
})();

function saveCart() {
    localStorage.setItem(CACHE_KEY, JSON.stringify({ cart, tipoAtencion, mesaSeleccionada, nombre: document.getElementById('inp-nombre').value, tel: document.getElementById('inp-tel').value }));
}

function loadCart() {
    const saved = localStorage.getItem(CACHE_KEY);
    if (saved) {
        try {
            const data = JSON.parse(saved);
            cart = data.cart || [];
            if (data.tipoAtencion) setTipoAtencion(data.tipoAtencion);
            if (data.mesaSeleccionada) seleccionarMesa(data.mesaSeleccionada);
            document.getElementById('inp-nombre').value = data.nombre || '';
            document.getElementById('inp-tel').value = data.tel || '';
        } catch(e) {}
    }
    renderCart();
}

function clearCart() {
    cart = []; mesaSeleccionada = ''; document.getElementById('inp-nombre').value = ''; document.getElementById('inp-tel').value = '';
    seleccionarMesa('');
    saveCart(); renderCart();
}

// ==== CATALOG ====
function renderCatalog(list) {
    const grid = document.getElementById('catalog-grid');
    const empty = document.getElementById('catalog-empty');
    if (!list.length) {
        grid.classList.add('hidden'); empty.classList.remove('hidden'); return;
    }
    empty.classList.add('hidden'); grid.classList.remove('hidden');
    grid.innerHTML = list.map(p => `
        <button onclick="addCart(${p.id})" class="bg-white hover:bg-indigo-50 border border-slate-200 p-3 rounded-xl shadow-sm hover:shadow-md transition-all text-left flex flex-col justify-between min-h-[90px] w-full group active:scale-95">
            <span class="font-bold text-slate-700 text-xs leading-snug group-hover:text-indigo-700 line-clamp-3 flex-1">${p.nombre}</span>
            <span class="text-sm font-black text-indigo-600 mt-2">$${p.precio.toFixed(2)}</span>
        </button>`).join('');
}

window.filtrarProductos = (q) => renderCatalog(allProductos.filter(p => p.nombre.toLowerCase().includes(q.toLowerCase())));

function addCart(id) {
    const prod = allProductos.find(p => p.id === id);
    if (!prod) return;
    const existing = cart.findIndex(c => c.servicioId === id && c.notasOpcionales === '');
    if (existing >= 0) cart[existing].cantidad++;
    else cart.push({ servicioId: prod.id, nombre: prod.nombre, precio: prod.precio, cantidad: 1, notasOpcionales: '' });
    renderCart(); saveCart();
}

window.updateQty = (idx, delta) => {
    cart[idx].cantidad += delta;
    if (cart[idx].cantidad <= 0) cart.splice(idx, 1);
    renderCart(); saveCart();
}
window.updateNotes = (idx, val) => { cart[idx].notasOpcionales = val; saveCart(); }

function renderCart() {
    const itemsEl = document.getElementById('cart-items');
    let total = 0;
    
    if (cart.length === 0) {
        itemsEl.innerHTML = `<div class="flex flex-col items-center justify-center h-full text-slate-400 p-6 text-center py-10"><span style="font-size:2rem;margin-bottom:.5rem;">🛒</span><p class="text-xs font-medium">Toca los productos para agregarlos.</p></div>`;
    } else {
        itemsEl.innerHTML = cart.map((c, i) => {
            total += c.precio * c.cantidad;
            return `
            <div class="bg-white border text-left p-3 rounded-xl shadow-sm border-slate-100 flex flex-col gap-1.5 mb-2">
                <div class="flex justify-between items-start">
                    <div class="flex-1"><p class="font-bold text-slate-800 text-sm leading-tight pr-2">${c.nombre}</p><p class="text-xs font-semibold text-slate-400">$${c.precio.toFixed(2)} c/u</p></div>
                    <div class="font-black text-indigo-600 text-sm">$${(c.precio * c.cantidad).toFixed(2)}</div>
                </div>
                <div class="flex justify-between items-center bg-slate-50 rounded-lg p-1.5 border border-slate-100">
                    <div class="flex-1 mr-2"><input type="text" placeholder="Notas (ej: sin cebolla)" value="${c.notasOpcionales}" oninput="updateNotes(${i}, this.value)" class="w-full bg-transparent border-b border-dashed border-slate-300 px-1 py-1 text-xs text-slate-600 focus:outline-none focus:border-indigo-400 placeholder-slate-400" /></div>
                    <div class="flex items-center gap-1.5 bg-white rounded-lg shadow-sm border border-slate-200 px-1">
                        <button onclick="updateQty(${i}, -1)" class="p-1.5 hover:text-red-500 text-slate-400 transition-colors font-bold ${c.cantidad===1?'text-red-400':''}">-</button>
                        <span class="text-xs font-black w-5 text-center text-slate-700">${c.cantidad}</span>
                        <button onclick="updateQty(${i}, 1)" class="p-1.5 hover:text-emerald-500 text-slate-400 transition-colors font-bold">+</button>
                    </div>
                </div>
            </div>`;
        }).join('');
    }
    
    document.getElementById('lbl-total').textContent = '$' + total.toFixed(2);
    document.getElementById('btn-confirmar').disabled = cart.length === 0;
}

// ==== UI Toggles ====
window.setTipoAtencion = (t) => {
    tipoAtencion = t;
    document.getElementById('btn-tipo-mesa').className = `px-2.5 py-1.5 font-bold transition-colors ${t==='Mesa'?'bg-indigo-600 text-white':'bg-slate-700 text-slate-300'}`;
    document.getElementById('btn-tipo-local').className = `px-2.5 py-1.5 font-bold transition-colors ${t==='Mostrador'?'bg-indigo-600 text-white':'bg-slate-700 text-slate-300'}`;
    document.getElementById('btn-tipo-llevar').className = `px-2.5 py-1.5 font-bold transition-colors ${t==='Llevar'?'bg-indigo-600 text-white':'bg-slate-700 text-slate-300'}`;
    
    if (t === 'Mesa') {
        document.getElementById('input-mesa-wrap').classList.remove('hidden'); document.getElementById('input-mesa-wrap').classList.add('flex');
        document.getElementById('input-text-wrap').classList.add('hidden'); document.getElementById('input-text-wrap').classList.remove('flex');
    } else {
        document.getElementById('input-mesa-wrap').classList.add('hidden'); document.getElementById('input-mesa-wrap').classList.remove('flex');
        document.getElementById('input-text-wrap').classList.remove('hidden'); document.getElementById('input-text-wrap').classList.add('flex');
        document.getElementById('inp-nombre').placeholder = t === 'Llevar' ? 'Nombre Cliente (Para Llevar)' : 'Nombre Cliente (Local)';
    }
    saveCart();
}

function renderMesas() {
    document.getElementById('mesas-wrap').classList.remove('hidden');
    document.getElementById('mesas-grid').innerHTML = mesas.map(m => `
        <button onclick="seleccionarMesa('${m.nombre}')" class="px-4 py-2.5 rounded-xl font-bold text-sm transition-all border active:scale-95 ${mesaSeleccionada === m.nombre ? 'bg-indigo-600 text-white border-indigo-600 shadow-lg shadow-indigo-500/30' : 'bg-white text-slate-700 border-slate-200 hover:bg-indigo-50 hover:border-indigo-300'}">🍽️ ${m.nombre}</button>
    `).join('');
}

window.seleccionarMesa = (m) => {
    mesaSeleccionada = m;
    renderMesas();
    document.getElementById('lbl-mesa-sel').textContent = m ? `🍽️ ${m}` : '🍽️ Selecciona una mesa...';
    saveCart();
}
window.clearMesa = () => seleccionarMesa('');

window.toggleOrders = () => {
    ordersOpen = !ordersOpen;
    document.getElementById('icon-chevron').innerHTML = ordersOpen ? (ICONS.chevronUp || '▲') : (ICONS.chevronDown || '▼');
    const c = document.getElementById('orders-content');
    if (ordersOpen) c.classList.remove('hidden'); else c.classList.add('hidden');
}

// ==== API ====
async function fetchComandas() {
    try {
        comandasActivas = await apiFetch('/Comandas/activas', { headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        document.getElementById('orders-badge').textContent = comandasActivas.length;
        renderActiveOrders();
    } catch(e){}
}

function renderActiveOrders() {
    const c = document.getElementById('orders-content');
    if (!comandasActivas.length) { c.innerHTML = '<p class="text-sm text-slate-400 text-center py-4">Sin órdenes activas</p>'; return; }
    
    c.innerHTML = comandasActivas.map(o => `
        <div class="flex flex-col bg-white rounded-xl border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between p-3 flex-wrap gap-2">
                <div class="min-w-0">
                    <p class="font-bold text-slate-800 text-sm truncate">${o.identificadorMesa || o.nombreCliente}</p>
                    <p class="text-xs text-slate-400">${new Date(o.fechaCreacion).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</p>
                </div>
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="px-2 py-1 rounded-full text-xs font-bold border ${o.estado==='Lista'?'bg-emerald-100 text-emerald-700 border-emerald-300':'bg-slate-100 text-slate-500'}">${o.estado}</span>
                    <span class="font-black text-slate-700 text-sm">$${o.total.toFixed(2)}</span>
                    ${(o.estado==='Lista'||o.estado==='Entregada')&&userAuth.rol!=='Cocinero' ? `<button onclick="cobrarComanda(${o.id})" class="bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1">Cobrar</button>` : ''}
                </div>
            </div>
            ${o.detalles && o.detalles.length ? `<div class="bg-slate-50 border-t border-slate-100 rounded-b-xl px-4 py-2 text-xs">${o.detalles.map(d=>`<div class="border-b border-dashed border-slate-200 py-1"><span class="font-bold text-slate-600">${d.cantidad}x </span><span class="text-slate-500">${d.nombreServicio||'Prod'}</span>${d.notasOpcionales?`<span class="text-red-500 font-bold ml-2">⚠️ ${d.notasOpcionales}</span>`:''}</div>`).join('')}</div>` : ''}
        </div>
    `).join('');
}

window.cobrarComanda = async (id) => {
    try {
        await apiFetch(`/Comandas/${id}/estado`, { method:'PUT', body:JSON.stringify({ nuevoEstado:'Cobrada'}), headers:{'X-Negocio-Id':NEGOCIO_ID.toString()} });
        fetchComandas(); showToast('Cobrada', 'success');
    } catch(e){}
}

window.enviarComanda = async () => {
    if (!cart.length) return;
    const finalName = tipoAtencion === 'Mesa' ? mesaSeleccionada : document.getElementById('inp-nombre').value;
    if (!finalName.trim()) return showToast('Indica la Mesa o Nombre del Cliente', 'error');

    const btn = document.getElementById('btn-confirmar');
    btn.disabled = true; btn.innerHTML = '<div class="spinner border-t-white w-4 h-4 border-2"></div> Enviando...';

    try {
        const payload = {
            telefonoCliente: document.getElementById('inp-tel').value.replace(/\D/g, ''),
            nombreCliente: finalName,
            identificadorMesa: finalName,
            tipoAtencion: tipoAtencion === 'Mesa' ? 'Mesas' : tipoAtencion,
            total: cart.reduce((s,c)=>s+(c.precio*c.cantidad),0),
            detalles: cart.map(c => ({ servicioId: c.servicioId, cantidad: c.cantidad, subtotal: c.precio*c.cantidad, notasOpcionales: c.notasOpcionales }))
        };

        await apiFetch('/Comandas', { method:'POST', body:JSON.stringify(payload), headers:{'X-Negocio-Id':NEGOCIO_ID.toString()} });
        
        document.getElementById('success-msg').textContent = `¡Comanda para ${finalName} enviada a cocina!`;
        document.getElementById('overlay-success').classList.remove('hidden');
        clearCart(); fetchComandas();
        
        setTimeout(() => document.getElementById('overlay-success').classList.add('hidden'), 3500);
    } catch(e) {
        showToast('Error: ' + e.message, 'error');
    } finally {
        btn.disabled = false; btn.innerHTML = '<span id="icon-send"></span> CONFIRMAR COMANDA';
    }
}
</script>
}
