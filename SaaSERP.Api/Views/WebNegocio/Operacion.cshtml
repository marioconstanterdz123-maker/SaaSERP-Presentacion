@{
    var negocioId = ViewBag.NegocioId;
    ViewData["Title"] = "Operación";
}
@await Html.PartialAsync("_NegocioShellTop")

<div class="h-full flex flex-col space-y-6">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-end mb-4 gap-4">
        <div>
            <h2 class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight flex items-center gap-3" id="page-title-h">
                <span id="icon-list-h"></span> Central de Operaciones
            </h2>
            <p class="text-sm md:text-base text-slate-500 mt-1" id="page-subtitle-h">El corazón del negocio. Gestiona ventas en mostrador en tiempo real.</p>
        </div>
        <div style="display:flex;gap:.5rem;align-items:center;">
            <span id="ping-dot" style="width:.75rem;height:.75rem;background:var(--emerald-500);border-radius:50%;display:inline-block;animation:ping 1s cubic-bezier(0,0,.2,1) infinite;"></span>
            <span style="font-size:.875rem;font-weight:700;color:var(--emerald-600);">En vivo</span>
        </div>
    </header>

    <div class="loading-center" id="loading"><div class="spinner spinner-orange"></div></div>

    <div id="content" class="hidden flex-col flex-1 animate-fade-in-up md:px-2"></div>
</div>

<!-- Modal Ingreso Manual Parqueadero -->
<div id="modal-placa" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm animate-fade-in text-left hidden">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-indigo-600 p-5 flex justify-between items-center text-white">
            <h3 class="font-bold tracking-wide">🚗 Registrar Entrada</h3>
            <button onclick="cerrarModalPlaca()" class="hover:bg-white/20 p-2 rounded-full transition-colors"><span id="icon-x-placa"></span></button>
        </div>
        <form id="form-placa" class="p-6 space-y-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Folio o Placa del Vehículo *</label>
                <input id="pk-placa" required type="text" placeholder="Ej. ABC-123" class="w-full text-center text-3xl tracking-widest uppercase bg-slate-50 border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-blue-500 font-black text-slate-800" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">📞 Teléfono cliente (opcional)</label>
                <input id="pk-telefono" type="tel" placeholder="528341234567" class="w-full text-sm bg-slate-50 border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 font-medium text-slate-700" />
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl shadow-lg hover:bg-blue-700 transition-colors active:scale-95 flex justify-center items-center gap-2">
                <span id="icon-check-placa"></span> Registrar Entrada
            </button>
        </form>
    </div>
</div>

<!-- Modal Cobro Parqueadero -->
<div id="modal-cobro" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm animate-fade-in hidden">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden text-center">
        <div class="bg-gradient-to-br from-emerald-500 to-teal-600 p-8 text-white">
            <div class="text-5xl mb-3">✅</div>
            <h3 class="text-2xl font-black tracking-tight">Salida Registrada</h3>
            <p id="mc-total" class="text-5xl font-black mt-4 drop-shadow">$0.00</p>
            <p class="text-sm mt-1 text-white/80">Total a cobrar</p>
        </div>
        <div class="p-6 space-y-3">
            <div class="flex justify-between text-sm font-medium text-slate-600 bg-slate-50 px-4 py-3 rounded-xl">
                <span>Placa</span>
                <span id="mc-placa" class="font-black text-slate-800 tracking-widest"></span>
            </div>
            <div class="flex justify-between text-sm font-medium text-slate-600 bg-slate-50 px-4 py-3 rounded-xl">
                <span>Tiempo de estadía</span>
                <span id="mc-tiempo" class="font-black text-slate-800"></span>
            </div>
            <button onclick="document.getElementById('modal-cobro').classList.add('hidden')" class="w-full mt-2 bg-slate-800 hover:bg-slate-900 text-white font-black py-4 rounded-2xl shadow-lg transition-colors active:scale-95">
                Cerrar
            </button>
        </div>
    </div>
</div>

<!-- Modal Cámara OCR -->
<div id="modal-camara" class="fixed inset-0 z-50 flex flex-col items-center justify-center p-4 bg-black/90 backdrop-blur-md animate-fade-in hidden">
    <div class="w-full max-w-md flex justify-between items-center mb-4 text-white">
        <h3 class="font-bold flex items-center gap-2"><span id="icon-video-cam"></span> Cámara Activa</h3>
        <button onclick="cerrarCamara()" class="bg-white/20 p-2 rounded-full hover:bg-white/40 border border-white/10"><span id="icon-x-cam"></span></button>
    </div>
    <div class="relative w-full max-w-md bg-black rounded-3xl overflow-hidden shadow-2xl border-4 border-slate-800 aspect-[3/4] md:aspect-video flex items-center justify-center">
        <video id="video-placa" autoplay playsinline class="w-full h-full object-cover"></video>
        <canvas id="canvas-placa" class="hidden"></canvas>
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-2/3 h-1/4 max-h-32 border-4 border-emerald-500/80 rounded-xl relative shadow-[0_0_0_9999px_rgba(0,0,0,0.5)]">
                <div class="absolute -top-1 -left-1 w-6 h-6 border-t-4 border-l-4 border-emerald-400"></div>
                <div class="absolute -top-1 -right-1 w-6 h-6 border-t-4 border-r-4 border-emerald-400"></div>
                <div class="absolute -bottom-1 -left-1 w-6 h-6 border-b-4 border-l-4 border-emerald-400"></div>
                <div class="absolute -bottom-1 -right-1 w-6 h-6 border-b-4 border-r-4 border-emerald-400"></div>
            </div>
            <p class="absolute bottom-8 text-emerald-400 font-bold text-sm bg-black/50 backdrop-blur-sm px-6 py-2 rounded-full animate-pulse border border-emerald-500/30">Alinee la placa en el recuadro</p>
        </div>
    </div>
    <div class="mt-8 w-full max-w-md flex flex-col gap-4">
        <button id="btn-scan" onclick="simularLecturaPlaca()" class="w-full text-white font-black py-4 rounded-2xl shadow-[0_0_20px_rgba(16,185,129,0.4)] transition-transform flex justify-center items-center gap-3 bg-emerald-500 hover:bg-emerald-600 active:scale-95">
            <span id="icon-cam-btn"></span> Capturar y Extraer Texto
        </button>
    </div>
</div>

<!-- Modal Nueva Cita -->
<div id="modal-cita" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm animate-fade-in text-left hidden">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden">
        <div class="bg-gradient-to-r from-fuchsia-600 to-pink-600 p-5 flex justify-between items-center text-white">
            <h3 class="font-bold tracking-wide">Agendar Cita</h3>
            <button onclick="document.getElementById('modal-cita').classList.add('hidden')" class="hover:bg-white/20 p-2 rounded-full transition-colors"><span id="icon-x-cita"></span></button>
        </div>
        <form id="form-cita" class="p-6 space-y-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Nombre del Cliente</label>
                <input id="c-nombre" required type="text" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 font-medium text-slate-800 focus:ring-2 focus:ring-pink-500 focus:outline-none" placeholder="Ej. Juan Pérez" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Teléfono</label>
                    <input id="c-tel" required type="tel" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 font-medium text-slate-800 focus:ring-2 focus:ring-pink-500 focus:outline-none" placeholder="555-0000" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Fecha y Hora</label>
                    <input id="c-fecha" required type="datetime-local" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 font-medium text-slate-800 focus:ring-2 focus:ring-pink-500 focus:outline-none" />
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Especialista (Opcional)</label>
                <select id="c-rec" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 font-medium text-slate-800 focus:ring-2 focus:ring-pink-500 focus:outline-none">
                    <option value="0">Sin preferencia</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Servicio (Opcional)</label>
                <select id="c-srv" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 font-medium text-slate-800 focus:ring-2 focus:ring-pink-500 focus:outline-none">
                    <option value="0">Escoger después</option>
                </select>
            </div>
            <div class="pt-2">
                <button type="submit" class="w-full bg-gradient-to-r from-fuchsia-500 to-pink-500 hover:from-fuchsia-600 hover:to-pink-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-pink-500/30 transition-all active:scale-95 flex items-center justify-center gap-2">
                    <span id="icon-check-cita"></span> Agendar y Disponer
                </button>
            </div>
        </form>
    </div>
</div>

@await Html.PartialAsync("_NegocioShellBottom")

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
@section Scripts {
<script>
const NEGOCIO_ID = @negocioId;
let negocioData = null;
let currentData = []; // comandas, tickets o citas
let intervalId = null;
let filtroEstado = 'TODAS';
let stream = null;
let userAuth = null;
let catalogos = { recursos: [], servicios: [] };

(async function init() {
    userAuth = requireAuth();
    if (!userAuth) return;
    document.getElementById('icon-menu-btn').innerHTML = ICONS.menu;
    document.getElementById('icon-x-drawer').innerHTML = ICONS.x;
    document.getElementById('icon-list-h').innerHTML = ICONS.listOrdered || ICONS.menu;
    document.getElementById('icon-x-placa').innerHTML = ICONS.x;
    document.getElementById('icon-check-placa').innerHTML = ICONS.checkCircle;
    document.getElementById('icon-video-cam').innerHTML = ICONS.video;
    document.getElementById('icon-x-cam').innerHTML = ICONS.xSquare;
    document.getElementById('icon-cam-btn').innerHTML = ICONS.camera;
    document.getElementById('icon-x-cita').innerHTML = ICONS.xSquare;
    document.getElementById('icon-check-cita').innerHTML = ICONS.checkCircle;

    try {
        const res = await apiFetch('/negocios');
        negocioData = res.find(n => n.id == NEGOCIO_ID);
        renderNegocioNav(userAuth, negocioData);

        if (negocioData.sistemaAsignado === 'TAQUERIA' || negocioData.sistemaAsignado === 'RESTAURANTES') {
            document.getElementById('icon-list-h').innerHTML = ICONS.coffee || '☕';
            document.getElementById('page-title-h').innerHTML = `<span style="color:var(--orange-500);">${ICONS.coffee || '☕'}</span> Comandas Activas`;
            await cargarComandas();
            intervalId = setInterval(cargarComandas, 10000);
        } else if (negocioData.sistemaAsignado === 'PARQUEADERO') {
            document.getElementById('icon-list-h').innerHTML = ICONS.car || '🚗';
            document.getElementById('page-title-h').innerHTML = `<span style="color:var(--blue-500);">${ICONS.car || '🚗'}</span> Caseta de Control Vehicular`;
            await cargarVehiculos();
            intervalId = setInterval(cargarVehiculos, 10000);
        } else if (negocioData.sistemaAsignado === 'CITAS') {
            document.getElementById('icon-list-h').innerHTML = ICONS.scissors || '✂️';
            document.getElementById('page-title-h').innerHTML = `<span style="color:var(--fuchsia-500);">${ICONS.scissors || '✂️'}</span> Agenda de Hoy`;
            await cargarCitasYCatalogos();
            intervalId = setInterval(cargarCitas, 10000);
        } else {
            renderGeneric();
        }
    } catch(err) {
        console.error(err);
        showToast('Error cargando operación', 'error');
    } finally {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('content').classList.remove('hidden');
        document.getElementById('content').style.display = 'flex';
    }

    document.getElementById('form-placa').addEventListener('submit', registrarEntrada);
    document.getElementById('form-cita').addEventListener('submit', registrarCita);
})();

window.addEventListener('beforeunload', () => { if (intervalId) clearInterval(intervalId); cerrarCamara(); });

// ==== COMANDAS (RESTAURANTES/TAQUERIA) ====
async function cargarComandas() {
    try {
        currentData = await apiFetch('/Comandas/activas', { headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        renderComandas();
    } catch(err) {}
}

function renderComandas() {
    if (negocioData.sistemaAsignado !== 'TAQUERIA' && negocioData.sistemaAsignado !== 'RESTAURANTES') return;
    const content = document.getElementById('content');
    
    let html = `
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 md:mb-6 bg-white/60 p-3 md:p-4 rounded-3xl border border-white/40 shadow-sm backdrop-blur-md">
        <div class="flex items-center gap-3 mb-3 md:mb-0">
            <span style="color:var(--orange-500);">${ICONS.coffee || '☕'}</span>
            <div>
                <h3 class="text-base md:text-xl font-black text-slate-800 tracking-tight">Comandas Activas</h3>
                <p class="text-xs font-medium text-slate-500">${currentData.length} órdenes en curso</p>
            </div>
        </div>
        <div class="flex overflow-x-auto gap-1 md:gap-0 md:bg-slate-100 md:p-1 rounded-2xl w-full md:w-auto pb-1 md:pb-0 scrollbar-hide">
            ${['TODAS', 'Recibida', 'En Preparacion', 'Lista', 'Entregada'].map(est => 
                `<button onclick="setFiltroComanda('${est}')" class="flex-shrink-0 text-center px-3 md:px-4 py-2 rounded-xl text-xs font-bold transition-all ${filtroEstado === est ? 'bg-white shadow-md text-orange-600 md:shadow-md' : 'text-slate-500 bg-slate-100 md:bg-transparent'}">${est}</button>`
            ).join('')}
        </div>
    </div>`;

    const filtradas = currentData.filter(c => {
        if (filtroEstado === 'TODAS' && (c.estado === 'Lista' || c.estado === 'Entregada' || c.estado === 'Cobrada')) return false;
        if (filtroEstado !== 'TODAS' && c.estado !== filtroEstado) return false;
        return true;
    });

    if (filtradas.length === 0) {
        html += `
        <div class="flex-1 flex flex-col items-center justify-center bg-white/40 rounded-3xl border border-white/20 border-dashed py-12">
            <span class="text-slate-300 mb-4" style="font-size:3rem;">${ICONS.checkCircle || '✅'}</span>
            <h3 class="text-xl font-bold text-slate-400">Todo limpio en cocina</h3>
        </div>`;
    } else {
        html += `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 md:gap-6 content-start">`;
        filtradas.forEach(c => {
            const bgClass = {
                'Recibida': 'bg-rose-100 text-rose-700 border-rose-200',
                'En Preparacion': 'bg-amber-100 text-amber-700 border-amber-200',
                'Lista': 'bg-emerald-100 text-emerald-700 border-emerald-200',
                'Entregada': 'bg-indigo-100 text-indigo-700 border-indigo-200'
            }[c.estado] || 'bg-slate-100 text-slate-700 border-slate-200';

            const dts = (c.detalles || []).map(d => `
                <div class="flex justify-between items-start text-sm">
                    <div class="flex-1">
                        <span class="font-bold text-slate-700">${d.cantidad}x</span> <span class="text-slate-600">${d.nombreServicio || d.nombreProducto || 'Prod'}</span>
                        ${d.notasOpcionales ? `<p class="text-xs text-red-500 font-bold ml-4 mt-0.5">⚠️ ${d.notasOpcionales}</p>` : ''}
                    </div>
                </div>`).join('');

            let btnHtml = '';
            const r = userAuth.rol;
            if (c.estado === 'Recibida' && (r === 'Cocinero' || r === 'SuperAdmin' || r === 'AdminNegocio')) {
                btnHtml = `<button onclick="cambiarEstado(${c.id}, 'En Preparacion')" class="col-span-2 bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95">👨‍🍳 Cocinar</button>`;
            } else if (c.estado === 'En Preparacion' && (r === 'Cocinero' || r === 'SuperAdmin' || r === 'AdminNegocio')) {
                btnHtml = `<button onclick="cambiarEstado(${c.id}, 'Lista')" class="col-span-2 bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95">🔔 Marcar Lista</button>`;
            } else if (c.estado === 'Lista' && c.tipoAtencion === 'Mesas' && r !== 'Cocinero') {
                btnHtml = `<button onclick="cambiarEstado(${c.id}, 'Entregada')" class="col-span-2 bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95 text-lg">🍽️ Entregar a Mesa</button>`;
            } else if (c.estado === 'Lista' && c.tipoAtencion !== 'Mesas' && (r === 'Cajero' || r === 'SuperAdmin' || r === 'AdminNegocio')) {
                btnHtml = `<button onclick="cambiarEstado(${c.id}, 'Cobrada')" class="col-span-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95 text-lg">🛍️ Entregar y Cobrar $${c.total.toFixed(2)}</button>`;
            } else if (c.estado === 'Entregada' && (r === 'Cajero' || r === 'SuperAdmin' || r === 'AdminNegocio')) {
                btnHtml = `<button onclick="cambiarEstado(${c.id}, 'Cobrada')" class="col-span-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95 text-lg">💳 Cobrar $${c.total.toFixed(2)}</button>`;
            }

            html += `
            <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-5 shadow-lg border border-slate-100 flex flex-col hover:-translate-y-1 transition-transform">
                <div class="flex justify-between items-start mb-4">
                    <span class="px-3 py-1 rounded-full text-xs font-bold border ${bgClass}">${c.estado}</span>
                </div>
                <h4 class="text-xl md:text-2xl font-black text-slate-800 tracking-tight leading-tight mb-1">${c.nombreCliente || c.identificadorMesa || 'Cliente'}</h4>
                <p class="text-sm font-bold text-orange-600 mb-4 flex items-center gap-1">${c.tipoAtencion === 'Llevar' ? '🛵 Para Llevar' : `🍽️ ${c.identificadorMesa || c.tipoAtencion}`}</p>
                <div class="bg-slate-50 rounded-2xl p-4 mb-4 flex-1">
                    <div class="mb-3 space-y-1.5">${dts}</div>
                    <div class="border-t border-slate-200 pt-2 mt-2">
                        <div class="flex justify-between text-sm mb-1"><span class="text-slate-500 font-medium">Llegada:</span><span class="font-bold text-slate-700">${new Date(c.fechaCreacion).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span></div>
                        <div class="flex justify-between text-sm"><span class="text-slate-500 font-medium">A cobrar:</span><span class="font-black text-emerald-600">$${c.total.toFixed(2)}</span></div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2 mt-auto">${btnHtml}</div>
            </div>`;
        });
        html += `</div>`;
    }
    content.innerHTML = html;
}

window.setFiltroComanda = function(est) { filtroEstado = est; renderComandas(); }

async function cambiarEstado(id, nuevoEstado) {
    try {
        await apiFetch(`/Comandas/${id}/estado`, { method: 'PUT', body: JSON.stringify({ nuevoEstado }), headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        cargarComandas();
    } catch(err) { console.error(err); }
}

// ==== PARQUEADERO ====
async function cargarVehiculos() {
    try {
        currentData = await apiFetch('/Tickets/activas', { headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        renderParqueadero();
    } catch(err) {}
}

function renderParqueadero() {
    if (negocioData.sistemaAsignado !== 'PARQUEADERO') return;
    const content = document.getElementById('content');
    
    let html = `
    <div class="flex flex-col p-6 bg-white/70 backdrop-blur-xl rounded-3xl border border-white/20 shadow-xl flex-1 overflow-y-auto">
        <div class="flex flex-col items-center text-center mb-6">
            <span style="font-size:3.5rem;margin-bottom:1rem;">🚗</span>
            <p class="text-slate-500 max-w-md text-sm">Escanea placas con la cámara o regístralas manualmente. Los vehículos activos aparecen abajo.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-md mx-auto mb-6">
            <button onclick="abrirCamara()" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-4 px-4 rounded-2xl shadow-lg shadow-emerald-500/30 transition-transform active:scale-95 flex items-center justify-center gap-2">📷 Escanear Placa</button>
            <button onclick="abrirModalPlaca()" class="bg-slate-800 hover:bg-slate-900 text-white font-bold py-4 px-4 rounded-2xl shadow-lg transition-transform active:scale-95 flex items-center justify-center gap-2">⌨️ Registro Manual</button>
        </div>`;

    if (currentData.length > 0) {
        html += `
        <div class="mt-8 w-full">
            <h4 class="text-left font-black text-slate-700 mb-4 flex justify-between items-center text-lg">
                <span>🚘 Vehículos Adentro</span>
                <span class="bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-sm font-bold">${currentData.length} Ocupados</span>
            </h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">`;
        
        currentData.forEach(v => {
            const min = Math.floor((Date.now() - new Date(v.horaEntrada).getTime())/60000);
            const hh = String(Math.floor(min/60)).padStart(2,'0');
            const mm = String(min%60).padStart(2,'0');
            const r = userAuth.rol;
            let btnHtml = '';
            if (r === 'Cajero' || r === 'SuperAdmin' || r === 'AdminNegocio') {
                btnHtml = `<button onclick="darSalida(${v.id}, '${v.placa}')" class="w-full bg-red-500 hover:bg-red-600 text-white font-black py-3 rounded-2xl shadow-md transition-transform active:scale-95 flex items-center justify-center gap-2">💳 Cobrar y Dar Salida</button>`;
            }

            html += `
            <div class="bg-white rounded-3xl shadow-md border border-slate-100 p-5 flex flex-col gap-3 hover:-translate-y-1 transition-transform">
                <div class="flex justify-between items-center">
                    <div class="text-xl md:text-3xl font-black text-slate-800 tracking-widest">${v.placa}</div>
                    <div class="bg-amber-100 text-amber-700 text-xs font-bold px-3 py-1 rounded-full">${hh}:${mm} h</div>
                </div>
                <div class="text-xs text-slate-400 font-medium">📥 Entrada: ${new Date(v.horaEntrada).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</div>
                ${v.telefono ? `<div class="text-xs text-slate-400">📞 ${v.telefono}</div>` : ''}
                ${btnHtml}
            </div>`;
        });
        html += `</div></div>`;
    }
    html += `</div>`;
    content.innerHTML = html;
}

window.abrirModalPlaca = () => { document.getElementById('modal-placa').classList.remove('hidden'); }
window.cerrarModalPlaca = () => { document.getElementById('modal-placa').classList.add('hidden'); document.getElementById('pk-placa').value=''; document.getElementById('pk-telefono').value=''; }

async function registrarEntrada(e) {
    e.preventDefault();
    try {
        await apiFetch('/Tickets/entrada', { 
            method: 'POST', 
            body: JSON.stringify({ placa: document.getElementById('pk-placa').value, telefonoContacto: document.getElementById('pk-telefono').value || null }),
            headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() }
        });
        cerrarModalPlaca();
        cargarVehiculos();
    } catch(err) { showToast(err.message || 'Error', 'error'); }
}

async function darSalida(id, placa) {
    try {
        const res = await apiFetch(`/Tickets/${id}/salida`, { method: 'PUT', headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        document.getElementById('mc-placa').textContent = res.placa || placa;
        document.getElementById('mc-tiempo').textContent = res.tiempoTotal || '';
        document.getElementById('mc-total').textContent = '$' + (res.cobro || 0).toFixed(2);
        document.getElementById('modal-cobro').classList.remove('hidden');
        cargarVehiculos();
    } catch(err) { showToast('Error procesando salida', 'error'); }
}

window.abrirCamara = async () => {
    document.getElementById('modal-camara').classList.remove('hidden');
    try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        document.getElementById('video-placa').srcObject = stream;
    } catch(err) { alert('No se pudo acceder a la cámara.'); cerrarCamara(); }
}
window.cerrarCamara = () => {
    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
    document.getElementById('modal-camara').classList.add('hidden');
    document.getElementById('btn-scan').disabled = false;
    document.getElementById('btn-scan').innerHTML = '<span id="icon-cam-btn"></span> Capturar y Extraer Texto';
    document.getElementById('icon-cam-btn').innerHTML = ICONS.camera;
}

window.simularLecturaPlaca = async () => {
    const video = document.getElementById('video-placa');
    const canvas = document.getElementById('canvas-placa');
    if (!video || !canvas) return;
    
    const btn = document.getElementById('btn-scan');
    btn.disabled = true;
    btn.innerHTML = 'Procesando...';

    try {
        canvas.width = video.videoWidth; canvas.height = video.videoHeight;
        canvas.getContext('2d').drawImage(video, 0, 0);
        const dataUrl = canvas.toDataURL('image/png');
        
        const result = await Tesseract.recognize(dataUrl, 'eng');
        let txt = result.data.text.replace(/[^A-Z0-9-]/gi, '').toUpperCase();
        if (txt.length < 2) txt = "LECTURA-MALA";
        
        cerrarCamara();
        document.getElementById('pk-placa').value = txt;
        abrirModalPlaca();
    } catch(err) { alert('Falló OCR'); cerrarCamara(); }
}

// ==== CITAS ====
async function cargarCitasYCatalogos() {
    try {
        const [citasRes, recRes, servRes] = await Promise.all([
            apiFetch('/Citas/activas', { headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } }),
            apiFetch(`/recursos/negocio/${NEGOCIO_ID}`),
            apiFetch(`/servicios/negocio/${NEGOCIO_ID}`)
        ]);
        currentData = citasRes; catalogos.recursos = recRes; catalogos.servicios = servRes;
        
        const selRec = document.getElementById('c-rec');
        selRec.innerHTML = '<option value="0">Sin preferencia</option>' + recRes.filter(r=>r.activo).map(r => `<option value="${r.id}">${r.nombre} (${r.tipo})</option>`).join('');
        
        const selSrv = document.getElementById('c-srv');
        selSrv.innerHTML = '<option value="0">Escoger después</option>' + servRes.filter(s=>s.activo).map(s => `<option value="${s.id}">${s.nombre} - $${s.precioBase || s.precio}</option>`).join('');

        renderCitas();
    } catch(err) {}
}

async function cargarCitas() {
    try {
        currentData = await apiFetch('/Citas/activas', { headers: { 'X-Negocio-Id': NEGOCIO_ID.toString() } });
        renderCitas();
    } catch(err) {}
}

function renderCitas() {
    if (negocioData.sistemaAsignado !== 'CITAS') return;
    const content = document.getElementById('content');
    
    let html = `
    <div class="flex justify-between items-center mb-6 bg-white/60 p-4 rounded-3xl border border-white/40 shadow-sm backdrop-blur-md">
        <div class="flex items-center gap-4">
            <span style="font-size:2rem;color:var(--fuchsia-500);">${ICONS.scissors || '✂️'}</span>
            <div>
                <h3 class="text-xl font-black text-slate-800 tracking-tight">Agenda de Hoy</h3>
                <p class="text-sm font-medium text-slate-500">${currentData.length} citas registradas</p>
            </div>
        </div>
        ${userAuth.rol !== 'Cocinero' ? `<button onclick="document.getElementById('modal-cita').classList.remove('hidden')" class="bg-gradient-to-r from-fuchsia-500 to-pink-500 hover:from-fuchsia-600 hover:to-pink-600 text-white font-bold py-2 px-6 rounded-2xl shadow-lg shadow-pink-500/30 transition-transform active:scale-95 flex items-center gap-2">➕ Nueva Cita</button>` : ''}
    </div>`;

    if (currentData.length === 0) {
        html += `<div class="flex-1 flex flex-col items-center justify-center bg-white/40 rounded-3xl border border-white/20 border-dashed py-12"><span style="font-size:3rem;" class="text-slate-300 mb-4">${ICONS.checkCircle || '✅'}</span><h3 class="text-xl font-bold text-slate-400">Sin citas para hoy</h3></div>`;
    } else {
        html += `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 content-start">`;
        currentData.forEach(c => {
            const r = userAuth.rol;
            let btnHtml = '';
            if (c.estado === 'Pendiente' && (r === 'Cajero' || r === 'SuperAdmin' || r === 'AdminNegocio')) {
                btnHtml = `<button onclick="cambiarEstadoCita(${c.id}, 'Completada')" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95 text-lg">✅ Terminar y Cobrar</button>`;
            } else if (c.estado === 'Pendiente' && r === 'Mesero') {
                btnHtml = `<button onclick="cambiarEstadoCita(${c.id}, 'Completada')" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl shadow-md transition-transform active:scale-95 text-lg">✅ Marcar Completada</button>`;
            } else if (c.estado === 'Completada') {
                btnHtml = `<button disabled class="bg-slate-200 text-slate-400 font-bold py-3 rounded-xl shadow-sm text-lg cursor-not-allowed">✔ Finalizada</button>`;
            }

            html += `
            <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-5 shadow-lg border border-slate-100 flex flex-col hover:-translate-y-1 transition-transform border-t-4 border-t-fuchsia-400">
                <div class="flex justify-between items-start mb-4">
                    <span class="px-3 py-1 rounded-full text-xs font-bold border ${c.estado === 'Completada' ? 'bg-emerald-100 text-emerald-700 border-emerald-200' : 'bg-amber-100 text-amber-700 border-amber-200'}">${c.estado}</span>
                </div>
                <h4 class="text-xl md:text-2xl font-black text-slate-800 tracking-tight leading-tight mb-1">${c.nombreCliente}</h4>
                <p class="text-sm font-bold text-fuchsia-600 mb-4 flex items-center gap-1">📞 ${c.telefonoCliente}</p>
                <div class="bg-slate-50 rounded-2xl p-4 mb-4 flex-1">
                    <div class="flex justify-between text-sm mb-1"><span class="text-slate-500 font-medium">Horario:</span><span class="font-bold text-slate-700">${new Date(c.fechaHoraInicio || c.fechaHora).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</span></div>
                </div>
                <div class="grid grid-cols-1 gap-2 mt-auto">${btnHtml}</div>
            </div>`;
        });
        html += `</div>`;
    }
    content.innerHTML = html;
}

window.cambiarEstadoCita = async (id, est) => {
    try {
        await apiFetch(`/Citas/${id}/estado`, { method:'PUT', body:JSON.stringify({ nuevoEstado: est }), headers: {'X-Negocio-Id': NEGOCIO_ID.toString()} });
        cargarCitas();
    } catch(err) {}
}

async function registrarCita(e) {
    e.preventDefault();
    try {
        const payload = {
            negocioId: NEGOCIO_ID,
            nombreCliente: document.getElementById('c-nombre').value,
            telefonoCliente: document.getElementById('c-tel').value,
            fechaHoraInicio: document.getElementById('c-fecha').value,
            duracionMinutos: 30,
            servicioId: parseInt(document.getElementById('c-srv').value) || null,
            recursoId: parseInt(document.getElementById('c-rec').value) || null
        };
        await apiFetch('/Citas/registrar', { method: 'POST', body: JSON.stringify(payload) });
        document.getElementById('modal-cita').classList.add('hidden');
        document.getElementById('form-cita').reset();
        cargarCitas();
    } catch(err) { showToast('Error al registrar', 'error'); }
}

function renderGeneric() {
