@{
    ViewData["Title"] = "Mis Negocios";
}

@await Html.PartialAsync("_AdminShellTop")

<!-- Page Header -->
<div class="page-header flex justify-between items-center">
    <div>
        <h2 class="page-title" id="icon-store-h2">Tus Negocios</h2>
        <p class="page-subtitle">Selecciona un negocio para acceder a su workspace.</p>
    </div>
    <button class="btn btn-primary" onclick="openModal()"><span id="icon-plus-btn"></span> Nuevo Negocio</button>
</div>

<!-- Loading -->
<div class="loading-center" id="loading"><div class="spinner"></div></div>

<!-- Grid de negocios -->
<div class="hidden" id="grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;"></div>

<!-- Empty state -->
<div class="card-plain text-center hidden" id="empty" style="padding:3rem;">
    <div style="font-size:3rem;margin-bottom:1rem;">🏪</div>
    <p class="font-bold" style="color:var(--slate-600);">Aún no hay negocios registrados.</p>
    <p class="text-sm" style="color:var(--slate-400);margin-top:.25rem;">Crea el primero con el botón de arriba.</p>
</div>

<!-- Modal Nuevo Negocio -->
<div id="modal" class="modal-backdrop hidden">
    <div class="modal">
        <div class="modal-header modal-header-admin">
            <span class="modal-title">Nuevo Negocio</span>
            <button class="btn-icon" onclick="closeModal()" id="icon-x-modal"></button>
        </div>
        <div class="modal-body">
            <div>
                <label class="label">Nombre del Negocio</label>
                <input id="m-nombre" class="input" placeholder="Ej. Taquería El Güero" />
            </div>
            <div>
                <label class="label">Sistema Asignado</label>
                <select id="m-sistema" class="input">
                    <option value="CITAS">Citas / Servicios</option>
                    <option value="TAQUERIA">Taquería / Restaurante</option>
                    <option value="RESTAURANTES">Restaurante Formal</option>
                    <option value="PARQUEADERO">Parqueadero / Estacionamiento</option>
                    <option value="TATTOO">Tattoo Studio</option>
                </select>
            </div>
            <div class="grid-2">
                <div>
                    <label class="label">Teléfono WhatsApp</label>
                    <input id="m-telefono" class="input" placeholder="+521234567890" />
                </div>
                <div>
                    <label class="label">Dirección</label>
                    <input id="m-direccion" class="input" placeholder="Calle, Ciudad" />
                </div>
            </div>
            <button class="btn btn-primary btn-full" onclick="crearNegocio()">
                <span id="icon-plus-modal"></span> Crear Negocio
            </button>
        </div>
    </div>
</div>

@await Html.PartialAsync("_AdminShellBottom")

@section Scripts {
<script>
const ADMIN_MENU = [
    { path: '/web/WebAdmin/Negocios',      name: 'Tus Negocios',  short: 'Negocios',  icon: 'store'    },
    { path: '/web/WebAdmin/Usuarios',      name: 'Usuarios',      short: 'Usuarios',  icon: 'users'    },
    { path: '/web/WebAdmin/Configuracion', name: 'Configuración', short: 'Config',    icon: 'settings' },
    { path: '/web/WebAdmin/Papelera',      name: 'Papelera',      short: 'Papelera',  icon: 'trash2'   },
];

(async function init() {
    const user = requireAuth();
    if (!user) return;

    // Render icons
    document.getElementById('icon-store-h2').prepend(Object.assign(document.createElement('span'),{innerHTML:ICONS.store}));
    document.getElementById('icon-plus-btn').innerHTML  = ICONS.plus;
    document.getElementById('icon-plus-modal').innerHTML = ICONS.plus;
    document.getElementById('icon-x-modal').innerHTML   = ICONS.x;
    document.getElementById('icon-x-drawer').innerHTML  = ICONS.x;
    document.getElementById('icon-menu-btn').innerHTML  = ICONS.menu;

    // Render sidebar nav
    renderAdminNav(user);
    cargarNegocios();
})();

function renderAdminNav(user) {
    const cur = window.location.pathname;
    const navHtml = ADMIN_MENU.map(m => `
      <a href="${m.path}" class="nav-link ${cur === m.path ? 'active-admin' : ''}">
        ${ICONS[m.icon] || ''} ${m.name}
      </a>`).join('');

    document.getElementById('sidebar-nav').innerHTML   = navHtml;
    document.getElementById('drawer-nav').innerHTML    = navHtml;
    document.getElementById('sidebar-user').innerHTML  = renderUserInfo(user, 'admin');
    document.getElementById('drawer-user').innerHTML   = renderUserInfo(user, 'admin');

    const bottomHtml = ADMIN_MENU.slice(0, 4).map(m => `
      <a href="${m.path}" class="nav-tab ${cur === m.path ? 'active' : ''}">
        ${ICONS[m.icon] || ''} <span>${m.short}</span>
      </a>`).join('');
    document.getElementById('bottom-nav').innerHTML = bottomHtml;
}

async function cargarNegocios() {
    try {
        const negocios = await apiFetch('/negocios');
        document.getElementById('loading').style.display = 'none';

        if (!negocios || negocios.length === 0) {
            document.getElementById('empty').classList.remove('hidden');
            document.getElementById('empty').style.display = 'block';
            return;
        }

        const grid = document.getElementById('grid');
        grid.style.display = 'grid';
        grid.innerHTML = negocios.map(n => negocioCard(n)).join('');
    } catch (err) {
        document.getElementById('loading').style.display = 'none';
        showToast('Error al cargar negocios: ' + err.message, 'error');
    }
}

function negocioCard(n) {
    const colorMap = {
        CITAS: ['#d946ef','#a855f7'], TAQUERIA: ['#f97316','#f43f5e'],
        RESTAURANTES: ['#f97316','#f43f5e'], PARQUEADERO: ['#3b82f6','#4f46e5'],
        TATTOO: ['#6366f1','#8b5cf6']
    };
    const [c1, c2] = colorMap[n.sistemaAsignado] || ['#64748b','#475569'];
    const activo = n.activo !== false;
    return `
      <div style="background:white;border-radius:1.5rem;overflow:hidden;box-shadow:var(--shadow-xl);border:1px solid var(--slate-100);transition:transform .2s,box-shadow .2s;cursor:pointer;"
           onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-2xl)'"
           onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow-xl)'"
           onclick="window.location.href='/web/negocio/${n.id}/Dashboard'">
        <div style="height:5rem;background:linear-gradient(135deg,${c1},${c2});position:relative;overflow:hidden;">
          <div style="position:absolute;right:-1rem;top:-1rem;width:6rem;height:6rem;background:rgba(255,255,255,.1);border-radius:50%;"></div>
          <span style="position:absolute;bottom:.75rem;left:1rem;font-size:.65rem;font-weight:700;color:rgba(255,255,255,.8);text-transform:uppercase;letter-spacing:.1em;">${n.sistemaAsignado}</span>
        </div>
        <div style="padding:1.25rem;">
          <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:.75rem;">
            <h3 style="font-weight:900;color:var(--slate-800);font-size:1.125rem;line-height:1.2;">${n.nombre}</h3>
            <span class="badge ${activo ? 'badge-green' : 'badge-red'}">${activo ? 'Activo' : 'Inactivo'}</span>
          </div>
          <p style="font-size:.75rem;color:var(--slate-400);font-weight:500;">${n.direccion || 'Sin dirección registrada'}</p>
        </div>
      </div>`;
}

function openModal()  { document.getElementById('modal').classList.remove('hidden'); }
function closeModal() { document.getElementById('modal').classList.add('hidden'); }

async function crearNegocio() {
    const payload = {
        nombre: document.getElementById('m-nombre').value,
        sistemaAsignado: document.getElementById('m-sistema').value,
        telefono: document.getElementById('m-telefono').value,
        direccion: document.getElementById('m-direccion').value,
        activo: true
    };
    if (!payload.nombre.trim()) { showToast('El nombre es obligatorio', 'error'); return; }
    try {
        await apiFetch('/negocios', { method: 'POST', body: JSON.stringify(payload) });
        showToast('Negocio creado correctamente', 'success');
        closeModal();
        document.getElementById('loading').style.display = 'flex';
        document.getElementById('grid').style.display = 'none';
        cargarNegocios();
    } catch (err) { showToast('Error: ' + err.message, 'error'); }
}
</script>
}
